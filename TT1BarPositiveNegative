using System;
using PowerLanguage.Function;

namespace PowerLanguage.Strategy 
{
    [IOGMode(IOGMode.Disabled)]
    public class TT1BarPositiveNegative : SignalObject 
    {
        private HighestFC m_HighestFC;
        private LowestFC m_LowestFC;

        private IOrderPriced m_PChLE;
        private IOrderPriced m_PChSE;

        public TT1BarPositiveNegative(object ctx) :
            base(ctx)
        {
            Length = 1;
        }

        [Input]
        public int Length { get; set; }

        protected override void Create(){
            m_HighestFC = new HighestFC(this);
            m_LowestFC = new LowestFC(this);
            m_PChLE = OrderCreator.Stop(new SOrderParameters(Contracts.Default, "PChLE", EOrderAction.Buy));
            m_PChSE = OrderCreator.Stop(new SOrderParameters(Contracts.Default, "PChSE", EOrderAction.SellShort));
        }

        protected override void StartCalc(){
            m_HighestFC.pricevalue = Bars.High;
            m_LowestFC.pricevalue = Bars.Low;
            m_HighestFC.len = Length;
            m_LowestFC.len = Length;
        }


        protected override void CalcBar(){
            
            if(Bars.Time.Value.Hour == 9 && Bars.Time.Value.Minute == 30)
            {
                if(Bars.Close[0] > Bars.Open[0])
                    m_PChLE.Send(m_HighestFC[0]+ Bars.Point);
                else if (Bars.Close[0] < Bars.Open[0])
                    m_PChSE.Send(m_LowestFC[0]+Bars.Point);
            }
            
            
            GenerateProfitTarget(200);
            GenerateStopLoss(100);
            
        }
    }
}
